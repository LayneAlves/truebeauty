<%- include('./include/head.ejs', {pagina:"carrinho"}) %>
  </head>

  <body>
    <%- include('./include/header.ejs') %>

      <main>
        <section class="page-header">
          <h1>Meu Carrinho</h1>
          <p>Revise seus itens antes de finalizar a compra</p>
        </section>

        <section class="carrinho-container">
          <div id="itens-carrinho" class="itens-carrinho">
          </div>

          <div class="resumo-carrinho">
            <h3>Resumo do Pedido</h3>
            <div class="total-container">
              <p id="total-carrinho">Total: R$ 0,00</p>
            </div>
            <button id="btn-checkout" class="btn-checkout">Finalizar Compra</button>
            <button id="btn-limpar" class="btn-limpar">Limpar Carrinho</button>
          </div>
        </section>
      </main>

      <%- include('./include/footer.ejs') %>

    <script>
      class CarrinhoPagina {
        constructor() {
          this.carrinho = JSON.parse(localStorage.getItem('carrinho')) || [];
          this.inicializar();
        }

        inicializar() {
          this.renderizarItens();
          this.configurarEventos();
        }

        renderizarItens() {
          const container = document.getElementById('itens-carrinho');

          if (this.carrinho.length === 0) {
            container.innerHTML = `
        <div class="carrinho-vazio">
          <h3>Seu carrinho está vazio</h3>
          <p>Adicione produtos para continuar</p>
          <a href="/" style="color: #8B0000;">Continuar comprando</a>
        </div>
      `;
            return;
          }

          container.innerHTML = this.carrinho.map(item => `
      <div class="item-carrinho" data-id="${item.id}">
        <img src="${item.imagem}" alt="${item.nome}">
        <div class="item-info">
          <h4>${item.nome}</h4>
          <p>${item.preco}</p>
        </div>
        <div class="item-controles">
          <input type="number" min="1" value="${item.quantidade}" class="quantidade-input" data-id="${item.id}">
          <button class="btn-remover" data-id="${item.id}">Remover</button>
        </div>
      </div>
    `).join('');

          this.atualizarTotal();
        }

        atualizarTotal() {
          const total = this.carrinho.reduce((sum, item) => {
            const preco = parseFloat(item.preco.replace('R$', '').replace(',', '.'));
            return sum + (preco * item.quantidade);
          }, 0);

          document.getElementById('total-carrinho').textContent =
            `Total: R$ ${total.toFixed(2).replace('.', ',')}`;
        }

        alterarQuantidade(id, quantidade) {
          const item = this.carrinho.find(item => item.id == id);
          if (item) {
            item.quantidade = parseInt(quantidade);
            localStorage.setItem('carrinho', JSON.stringify(this.carrinho));
            this.renderizarItens();
          }
        }

        removerItem(id) {
          this.carrinho = this.carrinho.filter(item => item.id != id);
          localStorage.setItem('carrinho', JSON.stringify(this.carrinho));
          this.renderizarItens();
        }

        limparCarrinho() {
          this.carrinho = [];
          localStorage.removeItem('carrinho');
          this.renderizarItens();
        }

        configurarEventos() {
          document.addEventListener('click', (e) => {
            if (e.target.classList.contains('btn-remover')) {
              this.removerItem(e.target.dataset.id);
            }
          });

          document.addEventListener('change', (e) => {
            if (e.target.classList.contains('quantidade-input')) {
              this.alterarQuantidade(e.target.dataset.id, e.target.value);
            }
          });

          document.getElementById('btn-checkout').addEventListener('click', () => {
            if (this.carrinho.length > 0) {
              window.location.href = 'checkout';
            } else {
              alert('Seu carrinho está vazio!');
            }
          });

          document.getElementById('btn-limpar').addEventListener('click', () => {
            if (confirm('Tem certeza que deseja limpar o carrinho?')) {
              this.limparCarrinho();
            }
          });
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        new CarrinhoPagina();
      });
    </script>
  </body>
</html>