<%- include('./include/head.ejs', {pagina:"cadastro"}) %>
  </head>

  <%- include('./include/header.ejs') %>

    <main>
      <section class="cadastro-section">

        <h1>Redefina sua senha</h1>

        <form action="/cadastro" method="post" class="cadastro-form" id="form-cadastro">

          <div class="form-group">
            <input type="password" id="senha" name="senha" placeholder=" " required>
            <label for="senha">Senha:</label>

            <ul id="senha-requisitos">
              <li id="req-length" class="invalid">Pelo menos 8 caracteres</li>
              <li id="req-case" class="invalid">Uma letra maiúscula e uma minúscula</li>
              <li id="req-number" class="invalid">Pelo menos um número</li>
              <li id="req-special" class="invalid">Pelo menos um caractere especial</li>
            </ul>

          </div>
          <div class="form-group">
            <input type="password" id="confirmar-senha" name="confirmar-senha" placeholder=" " required>
            <label for="confirmar-senha">Confirmar senha:</label>
            <span id="confirmar-senha-erro" class="field-message" style="display: none;">
              As senhas não coincidem
            </span>
            <span id="confirmar-senha-ok" class="field-message field-message--ok" style="display: none;">
              Senhas coincidem 
            </span>
          </div>

          <button type="submit" class="btn-cadastro">Cadastrar</button>

        </form>
      </section>
    </main>

    <!-- FOOTER -->
    <%- include('./include/footer.ejs') %>
      <script src="/assets/js/validacoes.js"></script>

      </body>

      </html>