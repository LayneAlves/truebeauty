<%- include('partials/header') %>

<main class="redefinir-container">
  <section class="redefinir-card">

    <div class="redefinir-logo">
      <img src="/assets/imagem/imagem_Logo/Logo2.png" alt="True Beauty">
    </div>

    <h2 class="redefinir-titulo">Criar nova senha</h2>
    <p class="redefinir-subtitulo">Escolha uma senha forte para proteger sua conta.</p>

    <div id="redefinir-msg" class="redefinir-feedback" style="display:none;"></div>

    <form id="form-redefinir" novalidate>
      <!-- Token oculto: vem da URL via EJS -->
      <input type="hidden" id="reset-token" value="<%= token %>">

      <div class="form-group">
        <input type="password" id="nova-senha" placeholder=" " required>
        <label for="nova-senha">Nova senha</label>
      </div>

      <div class="form-group">
        <input type="password" id="confirmar-senha" placeholder=" " required>
        <label for="confirmar-senha">Confirme a nova senha</label>
      </div>

      <!-- Indicador de forĂ§a da senha -->
      <div class="forca-senha-wrap">
        <div class="forca-senha-barra">
          <span id="forca-fill"></span>
        </div>
        <p id="forca-texto" class="forca-texto"></p>
      </div>

      <ul class="requisitos-lista" id="requisitos">
        <li id="req-tamanho">âś— MĂ­nimo de 8 caracteres</li>
        <li id="req-upper">âś— Letra maiĂşscula</li>
        <li id="req-lower">âś— Letra minĂşscula</li>
        <li id="req-numero">âś— NĂşmero</li>
        <li id="req-especial">âś— Caractere especial (!@#$â€¦)</li>
      </ul>

      <button type="submit" id="btn-redefinir" class="btn-login" disabled>
        Salvar nova senha
      </button>
    </form>

  </section>
</main>

<style>
  .redefinir-container {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f9f5f2;
    padding: 40px 16px;
  }

  .redefinir-card {
    background: #fff;
    border-radius: 12px;
    padding: 48px 40px;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    text-align: center;
  }

  .redefinir-logo img {
    height: 70px;
    margin-bottom: 24px;
  }

  .redefinir-titulo {
    font-family: 'Lora', serif;
    font-size: 22px;
    color: #1a1a1a;
    margin: 0 0 8px;
  }

  .redefinir-subtitulo {
    font-size: 14px;
    color: #777;
    margin: 0 0 28px;
  }

  .redefinir-feedback {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 20px;
    text-align: left;
  }

  .redefinir-feedback.sucesso {
    background: #eaf7ee;
    color: #2e7d45;
    border: 1px solid #b2dfca;
  }

  .redefinir-feedback.erro {
    background: #fdecea;
    color: #c0392b;
    border: 1px solid #f5c0bb;
  }

  /* Reutiliza .form-group do seu CSS global */

  /* Barra de forĂ§a */
  .forca-senha-wrap {
    margin: 12px 0 4px;
    text-align: left;
  }

  .forca-senha-barra {
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
  }

  #forca-fill {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 0.3s, background 0.3s;
  }

  .forca-texto {
    font-size: 12px;
    color: #888;
    margin: 4px 0 0;
    min-height: 16px;
  }

  /* Lista de requisitos */
  .requisitos-lista {
    list-style: none;
    padding: 0;
    margin: 12px 0 24px;
    text-align: left;
  }

  .requisitos-lista li {
    font-size: 13px;
    color: #c0392b;
    margin-bottom: 4px;
    transition: color 0.2s;
  }

  .requisitos-lista li.ok {
    color: #2e7d45;
  }

  .btn-login:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  const inputNovaSenha    = document.getElementById('nova-senha');
  const inputConfirmar    = document.getElementById('confirmar-senha');
  const btnRedefinir      = document.getElementById('btn-redefinir');
  const msgBox            = document.getElementById('redefinir-msg');
  const forcaFill         = document.getElementById('forca-fill');
  const forcaTexto        = document.getElementById('forca-texto');

  const reqTamanho  = document.getElementById('req-tamanho');
  const reqUpper    = document.getElementById('req-upper');
  const reqLower    = document.getElementById('req-lower');
  const reqNumero   = document.getElementById('req-numero');
  const reqEspecial = document.getElementById('req-especial');

  function validarRequisitos(senha) {
    const ok = {
      tamanho:  senha.length >= 8,
      upper:    /[A-Z]/.test(senha),
      lower:    /[a-z]/.test(senha),
      numero:   /\d/.test(senha),
      especial: /[~!@#$%^&*()_+\-=[\]{};':"\\|,.<>/?]/.test(senha)
    };

    reqTamanho.classList.toggle('ok', ok.tamanho);
    reqTamanho.textContent  = (ok.tamanho  ? 'âś“' : 'âś—') + ' MĂ­nimo de 8 caracteres';

    reqUpper.classList.toggle('ok', ok.upper);
    reqUpper.textContent    = (ok.upper    ? 'âś“' : 'âś—') + ' Letra maiĂşscula';

    reqLower.classList.toggle('ok', ok.lower);
    reqLower.textContent    = (ok.lower    ? 'âś“' : 'âś—') + ' Letra minĂşscula';

    reqNumero.classList.toggle('ok', ok.numero);
    reqNumero.textContent   = (ok.numero   ? 'âś“' : 'âś—') + ' NĂşmero';

    reqEspecial.classList.toggle('ok', ok.especial);
    reqEspecial.textContent = (ok.especial ? 'âś“' : 'âś—') + ' Caractere especial (!@#$â€¦)';

    const pontos = Object.values(ok).filter(Boolean).length;

    // Barra de forĂ§a
    const cores   = ['#e74c3c', '#e67e22', '#f1c40f', '#27ae60', '#1abc9c'];
    const labels  = ['', 'Fraca', 'RazoĂˇvel', 'Boa', 'Forte', 'Excelente'];
    forcaFill.style.width      = `${pontos * 20}%`;
    forcaFill.style.background = pontos > 0 ? cores[pontos - 1] : 'transparent';
    forcaTexto.textContent     = labels[pontos] || '';

    return Object.values(ok).every(Boolean);
  }

  function checarHabilitarBotao() {
    const tudo = validarRequisitos(inputNovaSenha.value);
    const igual = inputNovaSenha.value === inputConfirmar.value && inputConfirmar.value !== '';
    btnRedefinir.disabled = !(tudo && igual);
  }

  inputNovaSenha.addEventListener('input', checarHabilitarBotao);
  inputConfirmar.addEventListener('input', checarHabilitarBotao);

  // â”€â”€ Submit â”€â”€
  document.getElementById('form-redefinir').addEventListener('submit', async (e) => {
    e.preventDefault();
    msgBox.style.display = 'none';

    const token     = document.getElementById('reset-token').value;
    const novaSenha = inputNovaSenha.value;
    const confirmar = inputConfirmar.value;

    if (novaSenha !== confirmar) {
      mostrarMsg('As senhas nĂŁo coincidem.', 'erro');
      return;
    }

    btnRedefinir.disabled = true;
    btnRedefinir.textContent = 'Salvando...';

    try {
      const res  = await fetch('/redefinir-senha', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, novaSenha })
      });

      const data = await res.json();

      if (data.sucesso) {
        mostrarMsg(data.mensagem + ' Redirecionando para o inĂ­cio...', 'sucesso');
        setTimeout(() => window.location.href = '/', 3000);
      } else {
        mostrarMsg(data.mensagem, 'erro');
        btnRedefinir.disabled = false;
        btnRedefinir.textContent = 'Salvar nova senha';
      }
    } catch (err) {
      mostrarMsg('Erro de conexĂŁo. Tente novamente.', 'erro');
      btnRedefinir.disabled = false;
      btnRedefinir.textContent = 'Salvar nova senha';
    }
  });

  function mostrarMsg(texto, tipo) {
    msgBox.textContent  = texto;
    msgBox.className    = `redefinir-feedback ${tipo}`;
    msgBox.style.display = 'block';
  }
</script>

<%- include('partials/footer') %>
