<%- include('./include/head.ejs', {pagina:"cadastro"}) %>
  </head>

  <%- include('./include/header.ejs') %>

    <main>
      <section class="cadastro-section">

        <h1>Crie sua conta</h1>

        <form action="/cadastro" method="post" class="cadastro-form" id="form-cadastro">

          <div class="form-group">
            <input type="text" id="nome" name="nome" placeholder=" " required>
            <label for="nome">Nome:</label>
            <span id="nome-error" style="color:red; display:none;">
              Nome e sobrenome.
            </span>
          </div>

          <div class="form-group">
            <input type="email" id="emailTeste" name="email" placeholder=" " required>
            <label for="emailTeste">Email:</label>
            <span id="email-error" style="color:red; display:none;">
              Email inválido.
            </span>
          </div>

          <!-- Campos extras (estilo conta) -->
          <div class="conteudo">
            <div class="cp-form-group">
              <label class="cp-label" for="cpf">CPF</label>
              <input type="text" id="cpf" name="cpf" class="cp-input" placeholder="000.000.000-00">
            </div>

            <div class="cp-form-group">
              <label class="cp-label" for="genero">Gênero</label>
              <select id="genero" name="genero" class="cp-select">
                <option value="">Selecione...</option>
                <option value="feminino">Feminino</option>
                <option value="masculino">Masculino</option>
                <option value="outro">Outro</option>
                <option value="prefiro_nao_dizer">Prefiro não dizer</option>
              </select>
            </div>

            <div class="cp-form-group">
              <label class="cp-label" for="dataNascimento">Data de nascimento</label>
              <input type="date" id="dataNascimento" name="dataNascimento" class="cp-input">
            </div>

            <div class="cp-form-group">
              <label class="cp-label" for="telefone">Telefone</label>
              <input type="tel" id="telefone" name="telefone" class="cp-input" placeholder="(11) 99999-9999"
                autocomplete="tel">
            </div>

            <div class="cp-form-group">
              <label class="cp-label" for="senha">Senha</label>
              <input type="password" id="senha" name="senha" class="cp-input" placeholder="Sua senha"
                autocomplete="new-password" required>
              <ul id="senha-requisitos">
                <li id="req-length" class="invalid">Pelo menos 8 caracteres</li>
                <li id="req-case" class="invalid">Uma letra maiúscula e uma minúscula</li>
                <li id="req-number" class="invalid">Pelo menos um número</li>
                <li id="req-special" class="invalid">Pelo menos um caractere especial</li>
              </ul>
            </div>

            <div class="cp-form-group">
              <label class="cp-label" for="confirmar-senha">Confirmar senha</label>
              <input type="password" id="confirmar-senha" name="confirmar-senha" class="cp-input"
                placeholder="Repita a senha" autocomplete="new-password" required>
              <span id="confirmar-senha-erro" class="field-message" style="display: none;">
                As senhas não coincidem
              </span>
              <span id="confirmar-senha-ok" class="field-message field-message--ok" style="display: none;">
                Senhas coincidem
              </span>
            </div>

          </div>

          <button type="submit" class="btn-cadastro">Cadastrar</button>

        </form>
      </section>
    </main>

    <%- include('./include/footer.ejs') %>
      <script src="/assets/js/validacoes.js"></script>

      </body>

      </html>