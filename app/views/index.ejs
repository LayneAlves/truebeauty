<!DOCTYPE html>
<html lang="pt-br">

<!-- HEAD -->
<%- include('./include/head.ejs',{pagina:"index"}) %>
  </head>

  <body>

    <!-- HEADER -->
    <%- include('./include/header.ejs') %>

      <main>
        <!-- BANNER PRINCIPAL -->
        <section class="main-banner">
          <img src="assets/imagem/banners/dia-das-maes.webp" alt="Banner Dia das Mães">
        </section>

        <!-- CARROSSEL DE CATEGORIAS -->
        <div class="carousel-wrapper carousel-wrapper--categorias">
          <button type="button" class="scroll-arrow left"
            onclick="scrollCards('left', '.categories-carousel')">‹</button>

          <section class="categories-carousel">
            <section class="cabelo">
              <h2>Cabelo</h2>
              <a href="categoria?categoria=cabelos">Veja Mais</a>
            </section>
            <section class="corpo">
              <h2>Maquiagem</h2>
              <a href="categoria?categoria=maquiagens">Veja Mais</a>
            </section>
            <section class="banho">
              <h2>Cuidados</h2>
              <a href="categoria?categoria=cuidados_pessoais">Veja Mais</a>
            </section>
            <section class="perfume">
              <h2>Perfume</h2>
              <a href="categoria?categoria=perfumes">Veja Mais</a>
            </section>
            <section class="rosto">
              <h2>Skincare</h2>
              <a href="categoria?categoria=skin_care">Veja Mais</a>
            </section>
          </section>

          <button type="button" class="scroll-arrow right"
            onclick="scrollCards('right', '.categories-carousel')">›</button>
        </div>

        <!-- BANNER ROTATIVO -->
        <section class="custom-carousel">
          <div class="carousel-track">
            <img src="assets/imagem/banners/banner-cebolinha.jpeg" alt="Banner 1">
            <img src="assets/imagem/banners/banner-masculino.jpeg" alt="Banner 2">
            <img src="assets/imagem/banners/banner-feminino.jpeg" alt="Banner 3">
          </div>
          <div class="carousel-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
        </section>

        <!-- DESCRIÇÃO + BOTÃO -->
        <section class="description">
          <h3>Descubra a verdadeira beleza com nossos produtos.</h3>
        </section>

        <!-- CARROSSEL DE PRODUTOS -->
        <div class="carousel-wrapper">
          <button type="button" class="scroll-arrow left" onclick="scrollCards('left', '.card-container')">‹</button>

          <section class="card-container">
            <% produtos.forEach(produto=> { %>
              <section>
                <header>
                  <img src="<%=produto.imagem%>" alt="<%=produto.nome%>">
                </header>
                <article>
                  <h2 class="card-title">
                    <%=produto.nome%>
                  </h2>
                  <p class="card-text">
                    <%=produto.descricao%>
                  </p>
                  <p class="card-price">
                    <span class="currency">R$</span>
                    <%=produto.preco%>
                  </p>
                  <a href="#" class="card-button"
                    onclick="adicionarCarrinho('<%= produto.id %>', '<%= produto.nome %>', 'R$ <%= produto.preco %>', '<%= produto.imagem %>'); return false;">
                    Comprar
                  </a>
                </article>
              </section>
              <% }) %>
          </section>

          <button type="button" class="scroll-arrow right" onclick="scrollCards('right', '.card-container')">›</button>
        </div>

        <!-- Seção de destaque -->
        <div class="dica-make">
          <h2>Mais Vendidos</h2>
        </div>
        <div class="carousel-wrapper">
          <button type="button" class="scroll-arrow left" onclick="scrollCards('left')">‹</button>
          <div class="cards-container">

            <!-- Produto 1 -->
            <div class="card-destaque">
              <img class="img-fundo" src="assets/imagem/imagens_skin_care/emilia_clarke_1.webp"
                alt="Modelo com maquiagem">
              <div class="maisvendidos">
                <h3>Clinique iD</h3>
                <p class="preco">R$ 20,90</p>
                <button onclick="adicionarCarrinho('clinique-id', 'Clinique iD', 'R$ 20,90', 'assets/imagem/imagens_skin_care/clinique_id.jpg')">Comprar</button>
              </div>
            </div>

            <!-- Produto 2 -->
            <div class="card-destaque">
              <img class="img-fundo" src="assets/imagem/imagens_Cabelos/propagandaCachos.webp"
                alt="Modelo com maquiagem">
              <div class="maisvendidos">
                <h3>Salon Line</h3>
                <p class="preco">R$ 30,90</p>
                <button onclick="adicionarCarrinho('salon-line', 'Salon Line', 'R$ 30,90', 'assets/imagem/imagens_Cabelos/salonLine_coco.jpg')">Comprar</button>
              </div>
            </div>

            <!-- Produto 3 -->
            <div class="card-destaque">
              <img class="img-fundo" src="assets/imagem/imagens_Perfumes/propagandaMalbec.jpg"
                alt="Modelo com maquiagem">
              <div class="maisvendidos">
                <h3>Malbec</h3>
                <p class="preco">R$ 125,00</p>
                <button onclick="adicionarCarrinho('malbec', 'Malbec', 'R$ 125,00', 'assets/imagem/imagem_perfume_masculino/malbecMarrom.webp')">Comprar</button>
              </div>
            </div>

            <!-- Produto 4 -->
            <div class="card-destaque">
              <img class="img-fundo" src="assets/imagem/imagem_maquiagem/propagandaMaquiagem.jpg"
                alt="Modelo com perfume">
              <div class="maisvendidos">
                <h3>Dior</h3>
                <p class="preco">R$ 150,90</p>
                <button onclick="adicionarCarrinho('dior', 'Dior', 'R$ 150,90', 'assets/imagem/imagem_maquiagem/baseDior.jpg')">Comprar</button>
              </div>
            </div>

            <!-- Produto 5 -->
            <div class="card-destaque">
              <img class="img-fundo" src="assets/imagem/imagens_Cabelos/jadePicon.jpg" alt="Modelo com creme">
              <div class="maisvendidos">
                <h3>Eudora</h3>
                <p class="preco">R$ 140,00</p>
                <button onclick="adicionarCarrinho('eudora', 'Eudora', 'R$ 140,00', 'assets/imagem/imagens_Cabelos/kitEudoraRoxo.webp')">Comprar</button>
              </div>
            </div>

          </div>
          <button type="button" class="scroll-arrow right" onclick="scrollCards('right')">›</button>
        </div>

        <!-- Fim da seção -->

      </main>

      <!-- FOOTER -->
      <%- include('./include/footer.ejs') %>

        <!-- Banner Carrocel -->
        <script>
          const track = document.querySelector('.carousel-track');
          const dots = document.querySelectorAll('.carousel-dots .dot');
          const slides = track.children;
          let current = 0;

          function goToSlide(idx) {
            track.style.transform = `translateX(-${idx * 73}%)`;
            dots.forEach(dot => dot.classList.remove('active'));
            dots[idx].classList.add('active');
            current = idx;
          }

          dots.forEach((dot, idx) => {
            dot.addEventListener('click', () => goToSlide(idx));
          });

          setInterval(() => {
            let next = (current + 1) % slides.length;
            goToSlide(next);
          }, 3000);

          goToSlide(0);
        </script>

        <!-- Carrinho + Carrossel -->
        <script>
          // Função para adicionar ao carrinho (localStorage individual por dispositivo)
          function adicionarCarrinho(id, nome, preco, imagem) {
            let carrinho = JSON.parse(localStorage.getItem('carrinho')) || [];

            const itemExistente = carrinho.find(item => item.id == id);

            if (itemExistente) {
              itemExistente.quantidade += 1;
            } else {
              carrinho.push({ id, nome, preco, imagem, quantidade: 1 });
            }

            localStorage.setItem('carrinho', JSON.stringify(carrinho));
            alert(`"${nome}" adicionado à sacola!`);
          }

          // Função de seta para rolar TODOS os carrosséis
          function scrollCards(direction, selector = '.cards-container') {
            const container = document.querySelector(selector);
            const scrollAmount = 200;

            if (direction === 'left') {
              container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
            } else {
              container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            }
          }
        </script>

        <script>
          document.querySelectorAll('.categories-carousel section').forEach(section => {
            const link = section.querySelector('a');
            if (link) {
              section.addEventListener('click', () => {
                window.location.href = link.href;
              });
            }
          });
        </script>

  </body>

</html>
