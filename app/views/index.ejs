        <!-- Cliques nas Categorias-->
        <script>
          document.querySelectorAll('.categories-carousel section').forEach(section => {
            const link = section.querySelector('a');
            if (link) {
              section.addEventListener('click', () => {
                window.location.href = link.href;
              });
            }
          });
        </script>

  </body>

</html>