<div class="container__formulario-produto">
    <form id="cp-product-form" method="POST" action="/produtos/novo" enctype="multipart/form-data">
        <div class="cp-form-grid">

            <div class="conteudo">
                <!-- 1. Nome (span 2) -->
                <div class="cp-form-group cp-full-width">
                    <label class="cp-label" for="cp-nome">Nome do produto *</label>
                    <input type="text" id="cp-nome" name="nome" class="cp-input"
                        placeholder="Ex: Sérum Hidratante Facial" required>
                </div>

                <!-- 2. Preço | 3. Categoria -->
                <div class="cp-form-group">
                    <label class="cp-label" for="cp-preco">Preço (R$)*</label>
                    <input type="number" id="cp-preco" name="preco" class="cp-input" step="0.01" min="0"
                        placeholder="0.00" required>
                </div>
                <div class="cp-form-group">
                    <label class="cp-label" for="cp-categoria">Categoria *</label>
                    <select id="cp-categoria" name="categoria" class="cp-select" required>
                        <option value="">Selecione...</option>
                        <option value="cabelos">Cabelos</option>
                        <option value="perfumes">Perfumes</option>
                        <option value="cuidados_pessoais">Cuidados Pessoais</option>
                        <option value="skin_care">Skin Care</option>
                        <option value="maquiagens">Maquiagens</option>
                    </select>
                </div>

                <!-- 4. Estoque | 5. Subcategoria -->
                <div class="cp-form-group">
                    <label class="cp-label" for="cp-estoque">Estoque *</label>
                    <input type="number" id="cp-estoque" name="estoque" class="cp-input" min="0" placeholder="0"
                        required>
                </div>
                <div class="cp-form-group">
                    <label class="cp-label" for="cp-subcategoria">Subcategoria *</label>
                    <select id="cp-subcategoria" name="subcategoria" class="cp-select" required>
                        <option value="">Selecione...</option>
                        <option value="perfumes_feminino" data-categoria="perfumes">Perfume Feminino</option>
                        <option value="perfumes_masculino" data-categoria="perfumes">Perfume Masculino</option>
                        <option value="perfumes_infantil" data-categoria="perfumes">Perfume Infantil</option>
                        <option value="body_splash" data-categoria="perfumes">Bodysplash</option>
                        <option value="hidratacao" data-categoria="cabelos">Hidratação</option>
                        <option value="nutricao" data-categoria="cabelos">Nutrição</option>
                        <option value="reconstrucao" data-categoria="cabelos"> Reconstrução</option>
                        <option value="depilacao" data-categoria="cuidados_pessoais">Depilação</option>
                        <option value="higiene_intima" data-categoria="cuidados_pessoais">Higiene Íntima</option>
                        <option value="protetor_solar" data-categoria="cuidados_pessoais">Protetor Solar</option>
                        <option value="kit_barba" data-categoria="cuidados_pessoais">Kit de Barbear</option>
                        <option value="primer" data-categoria="maquiagens">Primer</option>
                        <option value="base" data-categoria="maquiagens">Base</option>
                        <option value="corretivo" data-categoria="maquiagens">Corretivo</option>
                        <option value="po" data-categoria="maquiagens">Pó</option>
                        <option value="batom" data-categoria="maquiagens">Batom</option>
                        <option value="olho" data-categoria="maquiagens">Olho</option>
                        <option value="rosto" data-categoria="skin_care">Rosto</option>
                        <option value="olhos" data-categoria="skin_care">Olhos</option>
                        <option value="labios" data-categoria="skin_care">Lábios</option>
                    </select>
                </div>

                <!-- 6. Descrição (span 2) -->
                <div class="cp-form-group cp-full-width">
                    <label class="cp-label" for="cp-descricao">Descrição</label>
                    <textarea id="cp-descricao" name="descricao" class="cp-textarea"
                        placeholder="Características e benefícios..."></textarea>
                </div>
            </div>


             <!-- upload de imagem -->
            <div class="container__imagem">
                <div class="cp-form-group">
                    <label class="cp-label">Imagem do produto *</label>
                    <div class="cp-upload-area" id="cp-upload-area">
                        <div class="cp-upload-icon">🖼️</div>
                        <div class="cp-upload-text">Clique para enviar</div>
                        <div class="cp-upload-subtext">JPG, PNG, WebP (máx. 5MB)</div>
                        <img id="cp-image-preview" class="cp-image-preview" alt="Preview">
                        <input type="file" id="cp-image-input" name="imagem" accept="image/*" style="display:none;"
                            required>
                    </div>
                </div>
            </div>

        </div>

</div>

<!-- Botões -->
<div class="cp-form-actions">
    <button type="button" class="cp-button cp-button-cancel" onclick="cpResetForm()">Cancelar</button>
    <button type="submit" class="cp-button cp-button-primary">Salvar Produto</button>
</div>

</form>
</div>
