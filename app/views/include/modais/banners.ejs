<div id="modal-banners" class="modal">
  <section class="modal-body">

    <div class="modal-header">
      <span class="ep-modal-close-icon" onclick="fecharModal()">×</span>
      <h2 class="title">NOVO BANNER</h2>
    </div>

    <div class="content">
      <form id="formNovoBanner" class="tb-form" method="POST" enctype="multipart/form-data">

        <!-- LADO ESQUERDO -->
        <section>

          <div class="tb-field">
            <label class="tb-label">Destino do Banner *</label>
            <select id="editDestino" name="destino" class="tb-input" required onchange="atualizarDestinoBanner()">
              <option value="hero">Banner Principal (Hero)</option>
              <option value="rotativo">Banner Rotativo</option>
            </select>
          </div>

          <p id="instrucaoRotativo" class="tb-instrucao"
            style="display:none; font-size: 13px; color: #8B0000; margin-bottom: 12px;">
            📌 O Banner Rotativo exige 3 imagens diferentes: uma para Desktop, uma para Tablet e uma para Mobile. As
            três são obrigatórias.
          </p>

          <div class="tb-field">
            <label class="tb-label">Título *</label>
            <input type="text" id="editNome" name="titulo" class="tb-input" placeholder="Título do banner" required>
          </div>

          <div class="tb-field">
            <label class="tb-label">Categoria *</label>
            <input type="text" id="editCategoria" name="categoria" class="tb-input" placeholder="Ex: Promoção de verão"
              required>
          </div>

          <div class="tb-field">
            <label class="tb-label">Alt *</label>
            <input type="text" id="editAlt" name="alt" class="tb-input" placeholder="Texto alternativo da imagem"
              required>
          </div>

          <div class="tb-field">
            <label class="tb-label">Link</label>
            <input type="text" id="editLink" name="link" class="tb-input" placeholder="Link no banner">
          </div>

          <div class="tb-row">
            <div class="tb-field">
              <label class="tb-label">Data início *</label>
              <input type="date" id="editDataInicio" name="data_inicio" class="tb-input" required>
            </div>
            <div class="tb-field">
              <label class="tb-label">Data fim</label>
              <input type="date" id="editDataFim" name="data_fim" class="tb-input">
            </div>
          </div>
        </section>

        <!-- LADO DIREITO (IMAGENS) -->
        <section class="tb-images-section">

          <div class="tb-field">
            <label class="tb-label">Imagem Desktop *</label>
            <label for="editImagemDesktopInput" class="tb-image-upload">
              <div class="tb-image-box" id="boxDesktop">
                <img id="editImagemDesktopPreview" class="tb-image-preview" alt="Preview da imagem desktop">
                <div class="tb-image-placeholder">
                  <span class="tb-image-icon">🖼️</span>
                  <p>Clique para enviar</p>
                </div>
              </div>
            </label>
            <input type="file" id="editImagemDesktopInput" name="imagemDesktop" accept="image/*" hidden required>
          </div>

          <div class="tb-field">
            <label class="tb-label" id="labelImagemTablet">Imagem Tablet</label>
            <label for="editImagemTabletInput" class="tb-image-upload">
              <div class="tb-image-box" id="boxTablet">
                <img id="editImagemTabletPreview" class="tb-image-preview" alt="Preview da imagem tablet">
                <div class="tb-image-placeholder">
                  <span class="tb-image-icon">🖼️</span>
                  <p>Clique para enviar</p>
                </div>
              </div>
            </label>
            <input type="file" id="editImagemTabletInput" name="imagemTablet" accept="image/*" hidden>
          </div>

          <div class="tb-field">
            <label class="tb-label" id="labelImagemMobile">Imagem Mobile</label>
            <label for="editImagemMobileInput" class="tb-image-upload">
              <div class="tb-image-box" id="boxMobile">
                <img id="editImagemMobilePreview" class="tb-image-preview" alt="Preview da imagem mobile">
                <div class="tb-image-placeholder">
                  <span class="tb-image-icon">🖼️</span>
                  <p>Clique para enviar</p>
                </div>
              </div>
            </label>
            <input type="file" id="editImagemMobileInput" name="imagemMobile" accept="image/*" hidden>
          </div>

        </section>
        
        <!-- BOTÕES -->
        <div class="ep-modal-actions">
          <button type="button" id="btnCancelar" class="tb-button-secondary">Cancelar</button>
          <button type="submit" class="tb-button-primary">Cadastrar</button>
        </div>

      </form>
    </div>

  </section>
</div>